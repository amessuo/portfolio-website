---
import styles from './BlogFooter.module.css'
---

<footer class={styles.footer}>
  <div class={`${styles.inner} container`}>
    <div class={styles.brand}>
      <div class={styles.logo}>
        <span class={styles.logoGreen}>THREE</span>
        <span class={styles.logoWhite}>DIGITAL</span>
      </div>
      <p class={styles.tagline}>
        Strategy-led digital marketing that drives measurable growth for startups and growing businesses.
      </p>
      <div class={styles.socialIcons}>
        <a href="https://www.linkedin.com/in/oussamabettaieb/" target="_blank" rel="noopener noreferrer" class={styles.socialIcon} aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <div class={styles.col}>
      <h4 class={styles.colTitle}>Pages</h4>
      <a href="/" class={styles.footerLink}>Home</a>
      <a href="/case-studies" class={styles.footerLink}>Case Studies</a>
      <a href="/blog" class={styles.footerLink}>Blog</a>
      <a href="/#contact" class={styles.footerLink}>Contact Us</a>
    </div>

    <div class={styles.col}>
      <h4 class={styles.colTitle}>Services</h4>
      <span class={styles.footerLink}>SEO Booster</span>
      <span class={styles.footerLink}>Marketing Strategy</span>
      <span class={styles.footerLink}>Data Analysis</span>
      <span class={styles.footerLink}>The AI Marketing Build</span>
    </div>
  </div>

  <div class={`${styles.bottom} container`}>
    <p class={styles.copyright}>&copy; {new Date().getFullYear()} ThreeDigital. All rights reserved.</p>
    <div class={styles.bottomLinks}>
      <a href="#" class={styles.bottomLink}>Privacy Policy</a>
      <a href="#" class={styles.bottomLink}>Terms &amp; Conditions</a>
    </div>
  </div>
</footer>
