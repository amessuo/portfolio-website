{
  "name": "portfolio-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "blog",
    "studio"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build --workspace=blog && cp -r blog/dist dist/blog && node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "dev:blog": "npm run dev --workspace=blog",
    "dev:studio": "npm run dev --workspace=studio",
    "build:blog": "npm run build --workspace=blog"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "framer-motion": "^11.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.0"
  }
}
